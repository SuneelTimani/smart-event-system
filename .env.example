NODE_ENV=development
PORT=5000
# Development: can be empty (localhost + LAN origins auto-allowed), or set explicit additional origins.
# Production: set strict allowlist (comma-separated), e.g. https://app.example.com
CORS_ALLOWED_ORIGINS=
MONGO_URI=your_mongodb_connection_string
JWT_SECRET=replace_with_a_long_random_secret
REDIS_URL=redis://127.0.0.1:6379
REDIS_RATE_LIMIT_PREFIX=smart_event_rate_limit
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback
WEB_EMAIL=suneeltimani@gmail.com
CLIENT_BASE_URL=http://localhost:5000
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com
NOTIFICATION_QUEUE_ENABLED=true
NOTIFICATION_QUEUE_POLL_MS=4000
NOTIFICATION_QUEUE_BATCH=10
NOTIFICATION_QUEUE_MAX_ATTEMPTS=5
NOTIFICATION_QUEUE_MAX_DELAY_MS=300000
EVENT_REMINDERS_ENABLED=true
EVENT_REMINDERS_POLL_MS=60000
EVENT_REMINDERS_GRACE_MS=600000
EVENT_REMINDERS_MAX_USERS=500
VAPID_SUBJECT=mailto:your_email@example.com
VAPID_PUBLIC_KEY=your_web_push_public_key
VAPID_PRIVATE_KEY=your_web_push_private_key
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_STATUS_CALLBACK_URL=https://your-domain.com/api/notifications/whatsapp-status
WEB_WHATSAPP_TO=+15551234567
CORS_ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000,http://192.168.100.44:5000
